{
  "extends": "@qlik/tsconfig/recommended",
  "compilerOptions": {
    /* JSX with preact (uses h factory, not React.createElement) */
    "jsx": "react",
    "jsxFactory": "h",

    /* Module resolution - use node for compatibility with existing imports */
    "moduleResolution": "node10",

    /* Incremental migration overrides - to be tightened over time */
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitReturns": false,
    "verbatimModuleSyntax": false,

    /* Keep allowJs off - all source files are now .ts */
    "allowJs": false
  },
  "include": ["packages/picasso.js/src/**/*.ts", "packages/picasso.js/src/**/*.tsx", "plugins/*/src/**/*.ts"],
  "exclude": ["**/node_modules", "**/dist", "**/__tests__", "**/*.spec.ts"]
}
